# Local dev — services talk to docker-compose.dev.yml infra.
# Copy to .env.dev and fill in LLM/SERP secrets.

# --- Infra (matches infra/docker-compose.dev.yml) ---
DATABASE_URL=postgresql://ava:ava@localhost:5432/ava
AMQP_URL=amqp://ava:ava@localhost:5672
JWKS_URI=http://localhost:8079/realms/ava/protocol/openid-connect/certs
JWKS_KID=replace-with-kid-from-jwks-uri

# --- Queue driver (D1) ---
QUEUE_DRIVER=rabbitmq

# --- DB driver (D3) ---
DB_CLIENT=direct

# --- LLM provider (D4) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_PROJECT_KEY=
OPENAI_ORGANIZATION_KEY=

# --- Service runtime ---
LOGLEVEL=debug
NODE_ENV=development

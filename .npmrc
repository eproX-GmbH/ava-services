# Workspace-level pnpm config.
#
# node-linker=hoisted — install a flat node_modules tree (npm-style) instead
# of pnpm's default symlinked + content-addressed layout. Required because:
#   - Legacy services (company-*, website) were authored for npm and assume
#     a flat layout (e.g. for tsconfig-paths resolution).
#   - Prisma generates its client into the consumer's node_modules/.prisma
#     by walking up from the @prisma/client package's *real* path. With
#     pnpm's default linker the real path is a shared store dir, so all
#     services end up sharing ONE generated client and stomp each other.
#   - Native modules (onnxruntime-node, etc.) bundle their .node binaries
#     in the package and resolve them via relative paths that break under
#     pnpm symlinks.
#
# auto-install-peers=true — silence the AI SDK peer warnings (zod range
# overlap; safe to auto-install).
node-linker=hoisted
auto-install-peers=true

{
  "name": "ava-meta",
  "private": true,
  "version": "0.0.0",
  "description": "AVA meta-repo: shared packages + service workspace for local dev and desktop bundling (see DECISIONS.md D2).",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "services/*",
    "company-profile",
    "company-contact",
    "company-publication",
    "company-evaluation",
    "website"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:hostlocal": "bash scripts/dev.sh hostlocal",
    "dev:hybrid": "bash scripts/dev.sh hybrid",
    "dev:desktop": "pnpm --dir services/desktop dev:real",
    "dev:desktop:mock": "pnpm --dir services/desktop dev:mock",
    "dev:all": "bash scripts/dev-all.sh hostlocal",
    "dev:all:dev": "bash scripts/dev-all.sh dev",
    "dev:all:hybrid": "bash scripts/dev-all.sh hybrid",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:check": "bash scripts/dev-stop.sh --check",
    "vendor:sync": "node scripts/vendor-sync.mjs",
    "vendor:check": "node scripts/check-vendor-drift.mjs",
    "postinstall": "node scripts/install-githooks.mjs"
  },
  "pnpm": {
    "overrides": {
      "@ava/auth": "workspace:*",
      "@ava/event": "workspace:*",
      "@ava/ai-provider": "workspace:*"
    }
  }
}

# Desktop / Electron mode — no local Postgres. DB access goes through the
# fly.io gateway (D3). Queue may be local NATS JetStream (D1) once the NATS
# driver lands; until then RabbitMQ over the hybrid stack.

DB_CLIENT=gateway
DB_GATEWAY_URL=https://<customer>.gateway.fly.dev
DB_GATEWAY_TOKEN=

QUEUE_DRIVER=rabbitmq
AMQP_URL=amqp://ava:ava@localhost:5672
# QUEUE_DRIVER=nats
# NATS_URL=nats://localhost:4222

JWKS_URI=
JWKS_KID=

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

ELASTIC_URL=
ELASTIC_API_KEY=

LOGLEVEL=info
NODE_ENV=production

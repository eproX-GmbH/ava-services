NODE_ENV=development
PORT=8080

# Gateway's own audit DB (separate from service DB)
DATABASE_URL=postgresql://ava:ava@localhost:5432/ava_gateway_audit
DIRECT_URL=postgresql://ava:ava@localhost:5432/ava_gateway_audit

# Upstream service base URLs. The gateway fans out to each service's
# existing REST surface (§4.1 company reads, etc. — see DESKTOP_DATA_FLOW.md).
UPSTREAM_MASTER_DATA_URL=http://localhost:3016
UPSTREAM_COMPANY_PROFILE_URL=http://localhost:3010
UPSTREAM_COMPANY_CONTACT_URL=http://localhost:3011
UPSTREAM_COMPANY_PUBLICATION_URL=http://localhost:3012
UPSTREAM_COMPANY_EVALUATION_URL=http://localhost:3013
UPSTREAM_WEBSITE_URL=http://localhost:3014
UPSTREAM_STRUCTURED_CONTENT_URL=http://localhost:3015

# JWT verification keys. JSON object: {"<tenantId>": "<PEM SPKI>"}.
# Private keys live with the customer's auth issuer, NOT here.
JWT_PUBLIC_KEYS={"acme-dev":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}
JWT_ISSUER=ava-auth
JWT_AUDIENCE=ava-gateway

RATE_LIMIT_PER_MIN=600
LOG_LEVEL=debug

# AMQP event bus (transaction.progress fan-out for the SSE bridge).
# Same exchange the services publish to.
EVENT_BUS_URL=amqp://ava:ava@localhost:5672
EVENT_BUS_EXCHANGE=exchange
EVENT_BUS_QUEUE=db-gateway-progress

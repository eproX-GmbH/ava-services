// Gateway-only schema. Per DECISIONS.md D3 the gateway does NOT mirror the
// full service schemas — it owns an audit log plus whatever operational
// tables get scoped in Step 5 from the Desktop-App's data flow.
//
// Per-service data is reached via a separate Prisma client connected to the
// upstream service database; that connection is configured at runtime in
// src/lib/prisma.ts, not declared here.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Per-company processing state across the producer chain (§8.v3).
///
/// One row per (transactionId, companyId, producer) — composite PK.
/// Persist-bus writes here as a side effect of applying each
/// `tenant.persist.<producer>.v1` event: state="completed" on a
/// successful upsert, state="failed" + errorMessage when the apply
/// throws. Compute-only producers don't need to know about this
/// table; the gateway derives entity state from event arrival.
///
/// Reads: `/v1/transactions/:id/entities` aggregates rows per
/// (transactionId, companyId) into a single per-company state — the
/// chat agent's `import_status` tool counts those buckets to answer
/// "how far is the import?". Pre-§8.v3 transactions whose entities
/// only ever existed in the legacy fly company-profile DB will show
/// up empty here; the gateway's entities route falls back to the
/// upstream call in that case so old transactions still report.
model EntityProgress {
  transactionId String
  companyId     String
  producer      String // matches PRODUCER_NAMES (lib/db-urls.ts)
  state         String // completed | failed | skipped
  errorMessage  String? // truncated to 500 chars at insert time
  updatedAt     DateTime
  createdAt     DateTime @default(now())

  /// v0.1.118 — heartbeat-driven auto-retry counters.
  ///
  /// `attempts` is the cumulative count of `state='failed'` transitions.
  /// Reset to 0 whenever a non-failed terminal state lands so a flake
  /// followed by success doesn't keep penalising the row.
  /// `firstFailureAt` is the wall-clock of the first failure in the
  /// current run of failures (cleared alongside `attempts`).
  /// `lastFailureAt` mirrors `updatedAt` but stays put across non-failed
  /// transitions; the orchestrator's "fewer-attempts-first" tie-breaker
  /// orders by it.
  /// `nextRetryAt` is the earliest moment the heartbeat orchestrator
  /// may re-pick the row. Set to NOW() + backoff(producer, attempts)
  /// on every failure.
  /// `giveUpAt` is set when `attempts >= MAX` AND the run is older
  /// than 24h; the orchestrator stops picking rows with a non-null
  /// `giveUpAt`. Manual retry clears it (the normal `in_progress` →
  /// terminal cycle resets every column).
  attempts       Int       @default(0)
  firstFailureAt DateTime?
  lastFailureAt  DateTime?
  nextRetryAt    DateTime?
  giveUpAt       DateTime?

  @@id([transactionId, companyId, producer])
  @@index([transactionId])
}

/// Operator-paid upstream proxy audit log (§8.v3 — today: valueserp).
///
/// One row per `/v1/proxy/<service>` call. Drives:
///   1. Rate limiting — count rows in a recent window
///      (per-minute/hour/day/month) to decide whether to admit the
///      next call. Limits live in env (VALUESERP_RATE_*) so the
///      operator can tune without a code change; per-tenant
///      overrides come from `ProxyQuotaOverride` below.
///   2. Cost / abuse review — `tenantId` × `proxy` over a date range
///      tells the operator who's burning the most upstream budget.
///   3. Forensics — `qHash` (sha256 of the canonicalized search params)
///      lets the operator correlate spikes without storing the literal
///      query (which can be PII / business-sensitive).
///
/// Append-only. Retention is a future concern; first cull TBD with
/// the customer once a few months of data are accumulated and we
/// know what cardinality looks like.
model ProxyAudit {
  id        BigInt   @id @default(autoincrement())
  proxy     String // 'valueserp' (room for more later)
  tenantId  String
  actorId   String
  qHash     String // sha256(canonicalized request body)
  status    Int // upstream HTTP status (or 429 for our own rate-limit)
  latencyMs Int // 0 if denied at the rate-limit gate
  cacheHit  Boolean  @default(false)
  createdAt DateTime @default(now())

  // Counter-window queries: WHERE proxy=$1 AND tenantId=$2 AND createdAt > NOW() - $window
  @@index([proxy, tenantId, createdAt])
  // Cost-attribution sweeps over a calendar month
  @@index([tenantId, createdAt])
}

/// Per-tenant override of the env-defined proxy rate limits.
///
/// All four columns are nullable: NULL means "fall back to env
/// default" so the operator can override only the dimension they
/// care about (e.g. raise just the monthly cap for paid customers).
/// `enabled = false` → hard-deny without consulting limits, useful
/// for incident response (cut a tenant immediately, sort it out
/// later). Keyed on (tenantId, proxy); a tenant can have separate
/// override rows per upstream when more proxies are added.
model ProxyQuotaOverride {
  tenantId  String
  proxy     String
  enabled   Boolean  @default(true)
  perMinute Int?
  perHour   Int?
  perDay    Int?
  perMonth  Int?
  // Free-text reason field — populated when the operator flips
  // `enabled` so future-them remembers why ("billed dispute 2026-06").
  note      String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@id([tenantId, proxy])
}

/// 24h response cache for proxy upstreams.
///
/// Same-query dedup across users on the same tenant. We hash
/// (proxy + canonicalized params) into `cacheKey`, store the JSON
/// response verbatim, and serve cache hits as if they were fresh
/// upstream responses (the audit row records `cacheHit=true` and
/// `latencyMs` of the local lookup, not the original upstream call).
///
/// `expiresAt` is set on insert (NOW() + VALUESERP_CACHE_TTL_HOURS).
/// A periodic cleanup task can DELETE WHERE expiresAt < NOW() — for
/// now we just let rows accumulate; at a few KB per row, even years
/// of cache fits in a tiny table.
model ProxyCache {
  cacheKey     String   @id // sha256(proxy + canonicalized params)
  proxy        String
  responseJson String // upstream response body verbatim
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
  @@index([proxy, createdAt])
}

/// Per-(company, stage) freshness + tier provenance (v0.1.62).
///
/// Backs the multi-tenant tier-aware persist gate. One row per
/// (companyId, stage) tracking when the canonical write last
/// happened and which LLM tier produced it (null for non-LLM
/// stages — structured-content, publication).
///
/// Persist-bus consults this table BEFORE applying any incoming
/// event:
///   - decides write/skip via @ava/ai-provider#tierShouldWrite
///   - writes the row post-apply on a successful write (last-
///     writer-wins on tier-eligible upgrades)
///
/// `llmTier` semantics:
///   1..4 — the tier (C..S) of the LLM that produced the write
///   null  — non-LLM stage OR pre-tier producer (legacy).
///           Treated as "downgrade-equivalent" by the comparison
///           helper; any tier-tagged producer can upgrade past it.
///
/// `llmModel` (v0.1.65) — exact model id that produced the write,
/// e.g. "gpt-4o", "qwen2.5:7b", "claude-sonnet-4-6". The tier is the
/// reliability bucket; the model id is the audit trail. Surfaced on
/// CompanyDetail tooltips and to the agent's company-context tool so
/// it can self-warn on low-tier sources. `null` for non-LLM stages
/// and for legacy rows written before this column landed.
model ContentFreshness {
  companyId String
  /// Producer name (= PRODUCER_NAMES). One stage per producer:
  /// "structured-content" | "company-publication" | "website" |
  /// "company-profile" | "company-contact" | "company-evaluation".
  stage     String
  llmTier   Int?
  llmModel  String?
  updatedAt DateTime @default(now())

  @@id([companyId, stage])
  // Per-company lookups (matrix view + producer pre-check in F3).
  @@index([companyId])
}

/// LLM-judge audit row for the website producer (v0.1.60).
///
/// Stores the verdict metadata for each company's website resolution
/// so admins can answer "why did the LLM pick foo.de over bar.de" or
/// "why did the LLM say no website exists" without having to dig
/// through producer logs.
///
/// One row per companyId — we overwrite on re-judges (e.g. freshness
/// rerun picks differently as ranking shifts). The history of past
/// verdicts is intentionally NOT kept; if we ever need that, the
/// existing AuditLog covers gateway request shape + the producer's
/// log-buffer shows the runtime details.
///
/// Storage rationale: producer DBs (ava_website, etc.) aren't on the
/// release_command migration path post-§8.v3, so adding columns there
/// is operationally fragile. The gateway's audit DB IS migrated on
/// every deploy, and read access is co-located with EntityProgress
/// which is the natural pairing for "matrix drilldown" UX.
model WebsiteJudgment {
  companyId            String   @id
  /// Non-null when LLM picked a candidate. null = "no match" verdict
  /// (LLM rejected all results) or "no SERP candidates" (empty page-1).
  matchIndex           Int?
  /// "high" | "medium" | "low". null when matchIndex is null.
  confidence           String?
  /// LLM's German-language explanation (≤200 chars at the source).
  reasoning            String?
  /// How many post-sponsor-strip candidates the LLM considered. Useful
  /// for distinguishing "company has no public site" (0 candidates)
  /// from "LLM rejected several" (>0 candidates + matchIndex null).
  candidatesConsidered Int
  /// Last time this row was written. Persist-bus updates on each
  /// successful website persist; same `last-write-wins` semantics as
  /// the Website / CompanySerp tables in the producer DB.
  judgedAt             DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Per-tenant billing state (M1 of monetization plan).
///
/// One row per tenant. Created on first usage write if not present
/// (defaults to Free / 25-lifetime). Stripe webhooks update `tier` +
/// `quotaLimit` + `periodEnd` after a Checkout success or
/// subscription change.
///
/// Why "tier" + "quotaLimit" rather than just "tier" with a hard-coded
/// lookup: lets the operator hand-edit a tenant's quota for support
/// cases (extra credits as a goodwill, custom enterprise contracts)
/// without code deploys.
///
/// `periodEnd` semantics:
///   - tier="free"  → null (lifetime quota; resets only via support)
///   - tier="starter" / "pro" → end of the current rolling-monthly window;
///     persist-bus rolls usage over to the next periodKey when this passes.
///   - tier="enterprise" → null (no quota enforced)
model TenantBilling {
  tenantId             String    @id
  tier                 String    @default("free")
  quotaLimit           Int       @default(25)
  // Stripe linkage when present.
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // Rolls over for paid tiers; null for free / enterprise.
  periodEnd            DateTime?
  /// v0.1.103 — Stripe's `cancel_at_period_end` mirrored here so the
  /// desktop can show "Kündigung zum X vorgemerkt" until period end.
  /// Webhook flips this on every subscription.updated event.
  cancelAtPeriodEnd    Boolean   @default(false)
  updatedAt            DateTime  @updatedAt
  createdAt            DateTime  @default(now())
}

/// Per-(tenant, period, company) usage credit (M1 of monetization plan).
///
/// Inserted by the persist-bus listener whenever
/// `tenant.persist.structured-content.v1` arrives — that's the
/// "company successfully enriched" signal. Unique on (tenantId,
/// periodKey, companyId) so:
///   - retries within the same period don't double-bill
///   - re-importing the same company in the same period is free
///     (cache hit, no new operator cost — see the design doc rationale)
///
/// `periodKey` shape:
///   - "lifetime" for the free tier (single grant, never resets)
///   - "YYYY-MM"  for paid tiers (rolling monthly window keyed on
///     the *charge* date, computed from TenantBilling.periodEnd)
///
/// `source` is the producer that emitted the persist event. Today
/// only "structured-content" billsthe quota; other producers (website,
/// company-profile, …) write their persist events but the listener
/// short-circuits since they're free downstream of structured-content.
model UsageEntry {
  tenantId  String
  periodKey String
  companyId String
  source    String
  createdAt DateTime @default(now())

  @@id([tenantId, periodKey, companyId])
  // Counter window for /v1/usage: count(*) where (tenantId, periodKey).
  @@index([tenantId, periodKey])
}

/// Workstream C — CRM linkage. Binds an AVA master-data companyId to
/// its counterpart in a connected CRM (HubSpot today; Salesforce +
/// Dynamics schema-ready, API stubbed). Written by the import paths
/// (Excel typed-header detection, HubSpot bulk import, single
/// `import_company` with explicit `crm` arg) and the future
/// "manuell verknüpfen" UI. Read by `GET /v1/companies/:id/crm`
/// and `GET /v1/companies/:id/crm/details`, which power the chat
/// agent's `company_crm_summary` tool.
///
/// Last-write-wins on (tenantId, companyId, crmType): re-importing
/// or re-confirming the same company under the same CRM replaces
/// the external id + display name. Tenant-scoped — one tenant's
/// HubSpot id never collides with another's.
model CompanyCrmLink {
  id              String          @id @default(cuid())
  tenantId        String
  companyId       String
  crmType         CrmType
  crmExternalId   String
  crmDisplayName  String?
  confirmedAt     DateTime        @default(now())
  confirmedSource ConfirmedSource
  lastSyncedAt    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([tenantId, companyId, crmType])
  @@index([tenantId, crmType, crmExternalId])
}

enum CrmType {
  HUBSPOT
  SALESFORCE
  DYNAMICS
}

enum ConfirmedSource {
  EXACT_MATCH // dry-run matchingType='direct'
  USER_CONFIRMED // user picked via ask_user_choice
  MANUAL_LINK // user clicked "Mit CRM verknüpfen" in UI
  SINGLE_IMPORT // import_company tool was called with explicit crm arg
}

/// JSON cache for enriched CRM payloads (contacts, deals, notes,
/// lastActivity). The read path serves cached rows when
/// `fetchedAt < 6h` ago; `refresh=true` or a stale row triggers a
/// fresh CRM call and overwrites this row. Single row per
/// (tenantId, companyId, crmType); no history is kept.
model CompanyCrmCache {
  id        String   @id @default(cuid())
  tenantId  String
  companyId String
  crmType   CrmType
  payload   Json
  fetchedAt DateTime @default(now())

  @@unique([tenantId, companyId, crmType])
  @@index([fetchedAt])
}

/// Append-only audit log. One row per gateway request after successful auth.
/// Retention policy TBD with the customer (fly.io secrets hold the cutoff).
model AuditLog {
  id           BigInt   @id @default(autoincrement())
  tenantId     String // customer id from JWT `tenant` claim
  actorId      String // user/service id from JWT `sub`
  method       String // HTTP method
  path         String // request path incl. /v1/...
  statusCode   Int
  requestId    String // X-Request-Id correlation
  durationMs   Int
  requestHash  String? // sha256 of body for high-integrity audits (optional)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([requestId])
}

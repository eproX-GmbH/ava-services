// Gateway-only schema. Per DECISIONS.md D3 the gateway does NOT mirror the
// full service schemas — it owns an audit log plus whatever operational
// tables get scoped in Step 5 from the Desktop-App's data flow.
//
// Per-service data is reached via a separate Prisma client connected to the
// upstream service database; that connection is configured at runtime in
// src/lib/prisma.ts, not declared here.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Per-company processing state across the producer chain (§8.v3).
///
/// One row per (transactionId, companyId, producer) — composite PK.
/// Persist-bus writes here as a side effect of applying each
/// `tenant.persist.<producer>.v1` event: state="completed" on a
/// successful upsert, state="failed" + errorMessage when the apply
/// throws. Compute-only producers don't need to know about this
/// table; the gateway derives entity state from event arrival.
///
/// Reads: `/v1/transactions/:id/entities` aggregates rows per
/// (transactionId, companyId) into a single per-company state — the
/// chat agent's `import_status` tool counts those buckets to answer
/// "how far is the import?". Pre-§8.v3 transactions whose entities
/// only ever existed in the legacy fly company-profile DB will show
/// up empty here; the gateway's entities route falls back to the
/// upstream call in that case so old transactions still report.
model EntityProgress {
  transactionId String
  companyId     String
  producer      String // matches PRODUCER_NAMES (lib/db-urls.ts)
  state         String // completed | failed | skipped
  errorMessage  String? // truncated to 500 chars at insert time
  updatedAt     DateTime
  createdAt     DateTime @default(now())

  @@id([transactionId, companyId, producer])
  @@index([transactionId])
}

/// Operator-paid upstream proxy audit log (§8.v3 — today: valueserp).
///
/// One row per `/v1/proxy/<service>` call. Drives:
///   1. Rate limiting — count rows in a recent window
///      (per-minute/hour/day/month) to decide whether to admit the
///      next call. Limits live in env (VALUESERP_RATE_*) so the
///      operator can tune without a code change; per-tenant
///      overrides come from `ProxyQuotaOverride` below.
///   2. Cost / abuse review — `tenantId` × `proxy` over a date range
///      tells the operator who's burning the most upstream budget.
///   3. Forensics — `qHash` (sha256 of the canonicalized search params)
///      lets the operator correlate spikes without storing the literal
///      query (which can be PII / business-sensitive).
///
/// Append-only. Retention is a future concern; first cull TBD with
/// the customer once a few months of data are accumulated and we
/// know what cardinality looks like.
model ProxyAudit {
  id          BigInt   @id @default(autoincrement())
  proxy       String   // 'valueserp' (room for more later)
  tenantId    String
  actorId     String
  qHash       String   // sha256(canonicalized request body)
  status      Int      // upstream HTTP status (or 429 for our own rate-limit)
  latencyMs   Int      // 0 if denied at the rate-limit gate
  cacheHit    Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Counter-window queries: WHERE proxy=$1 AND tenantId=$2 AND createdAt > NOW() - $window
  @@index([proxy, tenantId, createdAt])
  // Cost-attribution sweeps over a calendar month
  @@index([tenantId, createdAt])
}

/// Per-tenant override of the env-defined proxy rate limits.
///
/// All four columns are nullable: NULL means "fall back to env
/// default" so the operator can override only the dimension they
/// care about (e.g. raise just the monthly cap for paid customers).
/// `enabled = false` → hard-deny without consulting limits, useful
/// for incident response (cut a tenant immediately, sort it out
/// later). Keyed on (tenantId, proxy); a tenant can have separate
/// override rows per upstream when more proxies are added.
model ProxyQuotaOverride {
  tenantId    String
  proxy       String
  enabled     Boolean  @default(true)
  perMinute   Int?
  perHour     Int?
  perDay      Int?
  perMonth    Int?
  // Free-text reason field — populated when the operator flips
  // `enabled` so future-them remembers why ("billed dispute 2026-06").
  note        String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@id([tenantId, proxy])
}

/// 24h response cache for proxy upstreams.
///
/// Same-query dedup across users on the same tenant. We hash
/// (proxy + canonicalized params) into `cacheKey`, store the JSON
/// response verbatim, and serve cache hits as if they were fresh
/// upstream responses (the audit row records `cacheHit=true` and
/// `latencyMs` of the local lookup, not the original upstream call).
///
/// `expiresAt` is set on insert (NOW() + VALUESERP_CACHE_TTL_HOURS).
/// A periodic cleanup task can DELETE WHERE expiresAt < NOW() — for
/// now we just let rows accumulate; at a few KB per row, even years
/// of cache fits in a tiny table.
model ProxyCache {
  cacheKey    String   @id // sha256(proxy + canonicalized params)
  proxy       String
  responseJson String   // upstream response body verbatim
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
  @@index([proxy, createdAt])
}

/// Per-tenant billing state (M1 of monetization plan).
///
/// One row per tenant. Created on first usage write if not present
/// (defaults to Free / 25-lifetime). Stripe webhooks update `tier` +
/// `quotaLimit` + `periodEnd` after a Checkout success or
/// subscription change.
///
/// Why "tier" + "quotaLimit" rather than just "tier" with a hard-coded
/// lookup: lets the operator hand-edit a tenant's quota for support
/// cases (extra credits as a goodwill, custom enterprise contracts)
/// without code deploys.
///
/// `periodEnd` semantics:
///   - tier="free"  → null (lifetime quota; resets only via support)
///   - tier="starter" / "pro" → end of the current rolling-monthly window;
///     persist-bus rolls usage over to the next periodKey when this passes.
///   - tier="enterprise" → null (no quota enforced)
model TenantBilling {
  tenantId             String    @id
  tier                 String    @default("free")
  quotaLimit           Int       @default(25)
  // Stripe linkage when present.
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // Rolls over for paid tiers; null for free / enterprise.
  periodEnd            DateTime?
  updatedAt            DateTime  @updatedAt
  createdAt            DateTime  @default(now())
}

/// Per-(tenant, period, company) usage credit (M1 of monetization plan).
///
/// Inserted by the persist-bus listener whenever
/// `tenant.persist.structured-content.v1` arrives — that's the
/// "company successfully enriched" signal. Unique on (tenantId,
/// periodKey, companyId) so:
///   - retries within the same period don't double-bill
///   - re-importing the same company in the same period is free
///     (cache hit, no new operator cost — see the design doc rationale)
///
/// `periodKey` shape:
///   - "lifetime" for the free tier (single grant, never resets)
///   - "YYYY-MM"  for paid tiers (rolling monthly window keyed on
///     the *charge* date, computed from TenantBilling.periodEnd)
///
/// `source` is the producer that emitted the persist event. Today
/// only "structured-content" billsthe quota; other producers (website,
/// company-profile, …) write their persist events but the listener
/// short-circuits since they're free downstream of structured-content.
model UsageEntry {
  tenantId  String
  periodKey String
  companyId String
  source    String
  createdAt DateTime @default(now())

  @@id([tenantId, periodKey, companyId])
  // Counter window for /v1/usage: count(*) where (tenantId, periodKey).
  @@index([tenantId, periodKey])
}

/// Append-only audit log. One row per gateway request after successful auth.
/// Retention policy TBD with the customer (fly.io secrets hold the cutoff).
model AuditLog {
  id           BigInt   @id @default(autoincrement())
  tenantId     String // customer id from JWT `tenant` claim
  actorId      String // user/service id from JWT `sub`
  method       String // HTTP method
  path         String // request path incl. /v1/...
  statusCode   Int
  requestId    String // X-Request-Id correlation
  durationMs   Int
  requestHash  String? // sha256 of body for high-integrity audits (optional)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([requestId])
}

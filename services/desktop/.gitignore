node_modules/
out/
release/
.vite/
.DS_Store
*.log
*.tsbuildinfo
.electron-cache/

# Bundled binaries — populated by scripts/fetch-{ollama,whisper}.mjs at
# package time. Big (100s of MB), version-controlled via the script's
# pinned version constant, never via Git.
resources/ollama/*/
resources/whisper/*/
resources/postgres/*/
resources/producers/*/

# Derived icon working dir — `iconutil -c icns` regenerates from the
# source PNGs in /Users/mac/Desktop/Repos/ava-v2/public/ios. Only the
# final .icns / .ico / .png are checked in.
resources/icon.iconset/

# Gateway-side annotation overlay (Phase 8.f5 transaction-name +
# any future per-process state files). See lib/transaction-names.ts.
.gateway-data/

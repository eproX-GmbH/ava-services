{
  "name": "@ava/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AVA Electron desktop app — replaces user-interface/ Next.js. Talks to db-gateway only.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:mock": "AVA_DEV_AUTH_BYPASS=1 GATEWAY_URL=http://localhost:9080 electron-vite dev",
    "dev:real": "GATEWAY_URL=http://localhost:8081 AUTH_ISSUER=http://auth.localhost/realms/ava AUTH_CLIENT_ID=ava-desktop electron-vite dev",
    "mock-gateway": "node scripts/mock-gateway.mjs",
    "fetch:ollama": "node scripts/fetch-ollama.mjs",
    "build": "electron-vite build",
    "build:typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "preview": "electron-vite preview",
    "package:mac": "pnpm fetch:ollama --platform=darwin-arm64 && pnpm fetch:ollama --platform=darwin-x64 && electron-vite build && electron-builder --mac",
    "package:win": "pnpm fetch:ollama --platform=win32-x64 && electron-vite build && electron-builder --win",
    "package:linux": "pnpm fetch:ollama --platform=linux-x64 && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ava/ai-provider": "workspace:*",
    "@tanstack/react-query": "^5.40.0",
    "ai": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "yup": "^1.7.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}

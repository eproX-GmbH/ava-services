{
  "name": "@ava/desktop",
  "version": "0.1.67",
  "private": true,
  "description": "AVA Electron desktop app — replaces user-interface/ Next.js. Talks to db-gateway only.",
  "author": {
    "name": "eproX GmbH",
    "email": "hello@pattern-paradise.shop"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eproX-GmbH/ava-services.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:mock": "AVA_DEV_AUTH_BYPASS=1 GATEWAY_URL=http://localhost:9080 electron-vite dev",
    "dev:real": "GATEWAY_URL=http://localhost:8081 AUTH_ISSUER=http://auth.localhost/realms/ava AUTH_CLIENT_ID=ava-desktop electron-vite dev",
    "mock-gateway": "node scripts/mock-gateway.mjs",
    "fetch:ollama": "node scripts/fetch-ollama.mjs",
    "fetch:whisper": "node scripts/fetch-whisper.mjs",
    "fetch:producers": "node scripts/fetch-producers.mjs",
    "setup:mic": "node scripts/patch-electron-mic.mjs",
    "postinstall": "node scripts/patch-electron-mic.mjs",
    "build": "electron-vite build",
    "build:typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && node scripts/check-german.mjs",
    "lint:german": "node scripts/check-german.mjs",
    "audit:bundle": "node scripts/check-bundle-secrets.mjs",
    "preview": "electron-vite preview",
    "package:mac": "pnpm fetch:ollama --platform=darwin-arm64 && pnpm fetch:whisper --platform=darwin-arm64 && electron-vite build && electron-builder --mac --arm64",
    "package:win": "pnpm fetch:ollama --platform=win32-x64 && pnpm fetch:whisper --platform=win32-x64 && electron-vite build && electron-builder --win",
    "package:linux": "pnpm fetch:ollama --platform=linux-x64 && pnpm fetch:whisper --platform=linux-x64 && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ava/ai-provider": "workspace:*",
    "@electric-sql/pglite": "^0.4.5",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.40.0",
    "ai": "^5.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.14.0",
    "pg": "^8.20.0",
    "pg-gateway": "0.3.0-beta.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.0",
    "tailwindcss": "^4",
    "xlsx": "^0.18.5",
    "yup": "^1.7.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}

# Hybrid mode — services run locally, Postgres + Elasticsearch from cloud.
# Queue stays local (infra/docker-compose.hybrid.yml).

DATABASE_URL=postgresql://<user>:<pass>@<cloud-host>:5432/<db>
AMQP_URL=amqp://ava:ava@localhost:5672
JWKS_URI=https://<cloud-auth>/realms/ava/protocol/openid-connect/certs
JWKS_KID=

QUEUE_DRIVER=rabbitmq
DB_CLIENT=direct

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

ELASTIC_URL=https://<cloud-elastic>:9243
ELASTIC_API_KEY=

LOGLEVEL=info
NODE_ENV=development
